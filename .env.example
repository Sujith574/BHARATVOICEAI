NODE_ENV=development
APP_NAME=bharat-voice-backend
APP_VERSION=0.1.0
PORT=3000
API_PREFIX=/api/v1
PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:8081
LOG_LEVEL=info
TRUST_PROXY_HOPS=1

# ─── Database ─────────────────────────────────────────────────────────────────
# Use the pooled connection string from Supabase Dashboard → Settings → Database → Connection pooling
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Use the direct connection string from Supabase Dashboard → Settings → Database → Connection string
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
PRISMA_QUERY_LOGGING_ENABLED=false

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key
# Leave blank to auto-derive from SUPABASE_URL (recommended)
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
# Gemini API Key (found in Google AI Studio or Vertex AI console)
GEMINI_API_KEY=replace-with-your-gemini-api-key
# Sarvam AI API Key (found in Sarvam AI dashboard)
SARVAM_API_KEY=replace-with-your-sarvam-api-key

# ─── RBAC ─────────────────────────────────────────────────────────────────────
# Default role assigned to new admin users on first login (must exist in DB after seeding)
DEFAULT_ADMIN_ROLE_CODE=ADMIN_VIEWER
# Comma-separated list of emails that receive SUPER_ADMIN role on first login
SUPER_ADMIN_EMAILS=admin@example.gov.in

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_SIGNATURE_VALIDATION_ENABLED=false
TWILIO_MEDIA_STREAM_ENABLED=false
# Set to the publicly accessible WSS URL for your backend (used when TWILIO_MEDIA_STREAM_ENABLED=true)
TWILIO_MEDIA_STREAM_PUBLIC_URL=
# Must be at least 16 characters — sent as a token query param to authenticate the WebSocket upgrade
TWILIO_MEDIA_STREAM_SECRET=
TWILIO_DEFAULT_LANGUAGE=en-IN
WS_HEARTBEAT_INTERVAL_MS=15000
